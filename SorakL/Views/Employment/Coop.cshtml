@model List<SorakL.Models.CoopModel>

<section class="p-5">
    <div class="container">
        <h1 class="text-center mb-4">Co-op Employment</h1>

        <table id="coopTable" class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Employer</th>
                    <th>Degree</th>
                    <th>City</th>
                    <th>Term</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Employer</td>
                        <td>@item.Degree</td>
                        <td>@item.City</td>
                        <td>@item.Term</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

@section Styles {
    <!-- DataTables CSS -->
    <link rel="stylesheet"
          href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" />
}

@section Scripts {
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#coopTable').DataTable();
        });
    </script>
}