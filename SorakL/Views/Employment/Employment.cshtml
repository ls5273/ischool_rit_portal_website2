@model List<SorakL.Models.EmploymentModel>

<section class="p-5">
    <div class="container">
        <h1 class="text-center mb-4">Professional Employment</h1>

        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Employer</th>
                    <th>Title</th>
                    <th>Degree</th>
                    <th>City</th>
                    <th>Start Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var job in Model)
                {
                    <tr>
                        <td>@job.employer</td>
                        <td>@job.title</td>
                        <td>@job.degree</td>
                        <td>@job.city</td>
                        <td>@job.startDate</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
