@model List<SorakL.Models.GraduateModel>

<section class="p-5">
    <div class="container">
        <h1 class="text-center mb-4">Graduate Degrees</h1>

        @if (Model != null && Model.Any())
        {
            <div id="grad-tabs">
                <ul>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var degree = Model[i];
                        <li>
                            <a href="#grad-tab-@i">@degree.degreeName</a>
                        </li>
                    }
                </ul>

                @for (int i = 0; i < Model.Count; i++)
                {
                    var degree = Model[i];
                    <div id="grad-tab-@i" class="mt-3">
                        <div class="p-4 border rounded shadow-sm bg-light">
                            <h3 class="fw-bold">@degree.degreeName</h3>
                            <h5 class="text-muted">@degree.title</h5>

                            <p>@degree.description</p>

                            <h6 class="fw-bold mt-3">Concentrations / Certificates:</h6>

                            @if (degree.concentrations?.Any() == true)
                            {
                                <ul>
                                    @foreach (var c in degree.concentrations)
                                    {
                                        <li>@c</li>
                                    }
                                </ul>
                            }
                            else if (degree.availableCertificates?.Any() == true)
                            {
                                <ul>
                                    @foreach (var cert in degree.availableCertificates)
                                    {
                                        <li>@cert</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p><em>No concentrations or certificates available.</em></p>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p><em>No graduate degree data available.</em></p>
        }
    </div>
</section>

@section Styles {
    <style>
        #grad-tabs .ui-tabs-nav li a {
            font-weight: 600;
        }

        #grad-tabs .ui-tabs-panel {
            margin-top: 15px;
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#grad-tabs").tabs();
        });
    </script>
}
